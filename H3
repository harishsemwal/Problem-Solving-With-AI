✅ 📄 UPDATED CODE (SCROLL FIXED + SYNTAX FIXED)

<ng-container *ngIf="isConfirmationStep">

  <button
    pButton
    icon="pi pi-arrow-left"
    class="p-button-text"
    (click)="goBack()"
  ></button>

  <form [formGroup]="form">

    <div class="table-wrapper">
      <p-table
        [value]="rows.controls"
        [scrollable]="true"
        scrollHeight="400px"
        scrollDirection="both"
        styleClass="custom-table"
      >

        <ng-template pTemplate="header">
          <tr>
            <th class="col-request">Request</th>

            <th *ngFor="let field of selectedFields" class="col-dynamic">
              {{ field }}
            </th>

            <th class="col-action">Action</th>
          </tr>
        </ng-template>

        <ng-template pTemplate="body" let-row let-i="rowIndex">
          <tr [formGroup]="row">

            <td class="col-request">
              {{ row.value.requestName }}
            </td>

            <td *ngFor="let field of selectedFields" class="col-dynamic">
              <input
                pInputText
                [formControlName]="field"
              />
            </td>

            <td class="col-action">
              <button
                pButton
                icon="pi pi-trash"
                (click)="deleteRow(i)"
                [disabled]="rows.length === 1"
              ></button>
            </td>

          </tr>
        </ng-template>

      </p-table>
    </div>

  </form>

</ng-container>


